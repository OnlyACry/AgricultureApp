<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AgricultureApp.Views.FarmView"
             xmlns:vm="clr-namespace:AgricultureApp.ViewModels"
             Title="FarmView">
    <ContentPage.BindingContext>
        <vm:FarmViewModel/>
    </ContentPage.BindingContext>
    <ScrollView>
        <VerticalStackLayout>
            <VerticalStackLayout.Background>
                <!--渐变色-->
                <LinearGradientBrush StartPoint="0, 0" EndPoint="0, 1">
                    <GradientStop Color="#59C5B6" Offset="0"/>
                    <GradientStop Color="#F6FFFA" Offset="0.4"/>
                </LinearGradientBrush>
            </VerticalStackLayout.Background>
            <!--标题栏-->
            <HorizontalStackLayout HeightRequest="40" Margin="10, 30, 0, 0">
                <Image Source="logo.png" Margin="5,0"/>
                <Label Text="智慧农业" TextColor="White" FontSize="18" VerticalOptions="Center"/>
            </HorizontalStackLayout>

            <!--实时视频-->
            <Frame HeightRequest="170" Padding="0" HasShadow="True" CornerRadius="15" Margin="10">
                <Image Source="farm1.jpg" Aspect="AspectFill"/>
            </Frame>

            <Label Text="{Binding CameraList.Count,StringFormat='实时视频({0})'}" 
                   Margin="15, 5" 
                   FontAttributes="Bold" 
                   HorizontalOptions="Start"
                   TextColor="#555"/>

            <CollectionView HeightRequest="90" ItemsSource="{Binding CameraList}">
                <CollectionView.Header>
                    <Label WidthRequest="8"/>
                </CollectionView.Header>
                <CollectionView.Footer>
                    <Label WidthRequest="8"/>
                </CollectionView.Footer>
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Horizontal"/>
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame Padding="0"
                               HasShadow="True"
                               CornerRadius="10"
                               Margin="4"
                               BorderColor="Transparent"
                               WidthRequest="120">
                            <Grid>
                                <Image Source="{Binding}" Aspect="AspectFill"/>
                                <Ellipse WidthRequest="26"
                                         HeightRequest="26"
                                         Fill="#66000000"
                                         Stroke="White"
                                         StrokeThickness="1"
                                         VerticalOptions="Center"
                                         HorizontalOptions="Center"/>
                                <Path Data="M0 0 12 6 0 12"
                                      Fill="White"
                                      VerticalOptions="Center"
                                      HorizontalOptions="Center"/>
                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!--异常信息-->
            <Label Text="{Binding Errorlist.Count, StringFormat='异常信息({0})'}" 
                   Margin="15, 5" 
                   FontAttributes="Bold" 
                   HorizontalOptions="Start"
                   TextColor="#555"/>

            <CollectionView ItemsSource="{Binding Errorlist}">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame Padding="10"
                               HasShadow="True"
                               CornerRadius="10"
                               Margin="15, 5"
                               BorderColor="Transparent"
                               BackgroundColor="#FFFFF0">
                            <Grid ColumnDefinitions="50, *, 0.8*">
                                <!--部分一-图标-->
                                <Path  Data="M928.99 755.83 574.6 203.25c-12.89-20.16-36.76-32.58-62.6-32.58s-49.71 12.43-62.6 32.58L95.01 755.83c-12.91 20.12-12.9 44.91.01 65.03 12.92 20.12 36.78 32.51 62.59 32.49h708.78c25.82.01 49.68-12.37 62.59-32.49 12.91-20.12 12.92-44.91.01-65.03zM554.67 768h-85.33v-85.33h85.33V768zm0-426.67v298.66h-85.33V341.32l85.33.01z" 
                                       WidthRequest="30"
                                       HeightRequest="30"
                                       Aspect="Fill">
                                    <Path.Fill>
                                        <SolidColorBrush Color="{Binding Color}"/>
                                    </Path.Fill>
                                </Path>

                                <!--部分二-文字提示-->
                                <StackLayout Grid.Column="1" VerticalOptions="Center">
                                    <Label Text="{Binding Header}"
                                           FontAttributes="Bold"
                                           FontSize="15"/>
                                    <Label Text="{Binding Description}"
                                           FontSize="12"
                                           TextColor="{Binding Color}"/>
                                </StackLayout>

                                <!--第三部分-位置信息-->
                                <Frame Grid.Column="2" CornerRadius="16" HeightRequest="30" Padding="0" Background="#F2F7FC" BorderColor="Transparent">
                                    <StackLayout Orientation="Horizontal" VerticalOptions="Center" Margin="15, 0">
                                        <Path Data="M898 541.88c-15.6-16-31.6-32-47.2-48-90.8-91.2-182.8-181.6-273.2-273.6l-48-48c-7.6-9.6-22-11.6-31.6-3.6-1.2 1.2-2.8 2.4-3.6 3.6-21.2 21.2-42 42.4-63.2 64-100.8 101.6-202.8 202.8-303.6 304.8l-2.4 2.4c-3.6 4-5.2 9.2-4.8 14.8 0.4 12 10.4 21.2 22.4 21.2H245.2c4 0 5.6 0.8 5.2 5.2v126.8c0 41.6 0.4 83.2 0 124.8-0.8 12.8 9.2 24 22 24.4h480c12.8 0.4 24-9.6 24.4-22.4v-2c-0.4-83.6 0-167.6 0-251.2 0-5.6 0-5.6 5.6-5.6h100c9.2 0 17.2-5.6 20-14 3.2-8.4 1.2-17.6-4.4-23.6z m-74.4-6.8c-22.4 0-44.8 0.4-66.8 0-12.8-0.4-23.6 9.6-24 22.4v1.6c0.4 83.6 0 167.6 0 251.2 0 5.6 0 6-5.6 6H300c-4.4 0-5.6-1.2-5.6-5.6v-251.6c1.2-12-7.6-22.8-20-24H196c0.8-1.6 2-3.2 3.2-4.4 60.4-60.4 121.2-120.8 181.6-182 42.4-42.8 85.2-85.2 127.6-128 2.8-2.8 4.4-2.8 7.2 0 37.6 38 75.6 75.2 112.8 113.2 64.8 66.4 131.2 131.2 196.4 197.2 0.8 0.8 2 2 3.2 3.6l-4.4 0.4zM632.8 601.48c-2.4-6.4-6-12.4-11.2-17.2-5.6-5.2-12-9.2-19.2-11.6-8.8-2.8-17.6-3.6-26.8-2.4-7.2 0.8-14.4 2.4-21.2 5.2-7.2 2.8-14 6.4-20.8 10.4-6.4 4-12.4 8.8-18 14.4-5.2 4.8-9.6 10.4-13.2 16.8-3.2-6.8-7.2-12.8-11.6-18.8-4.8-6.4-10-12-15.2-17.6-5.2-5.2-11.2-10.4-17.2-14.8-5.2-4-10.8-7.2-16.8-10-5.2-2.4-10.4-4-16-5.2-5.2-1.2-10.8-1.6-16.4-1.2-5.2 0-10 1.2-14.8 2.8-4.4 1.6-8.4 4-12 7.2-3.6 3.6-7.2 8-10 12.4s-4.8 9.6-5.6 14.8c-0.8 5.2-0.8 10.8 0.8 16 1.6 5.6 13.6 49.6 85.6 68.4 8.4 2.4 17.6 2.4 26 0.4-2.8 12-5.2 25.2-7.2 40-2 15.6-3.2 31.2-3.2 46.8 0 12.8 0 23.6-0.4 32.4 0 8.8-0.4 16-0.8 21.2-0.4 6.4-0.8 11.6-0.8 15.6h36.8c-0.8-6.4-1.2-13.2-1.6-20-0.4-6-0.8-12.8-1.2-20s-0.4-14.8-0.4-22c0-15.2 0.8-30.8 2.8-46 2-14.8 4.4-28.8 6.8-41.2 89.2 10 114.4-33.6 118-39.2 3.6-5.6 5.6-11.6 6.4-18 1.2-6.8 0.4-13.6-1.6-19.6z"
                                              Fill="#72848A"
                                              WidthRequest="18"
                                              HeightRequest="18"
                                              Aspect="Uniform"
                                              VerticalOptions="Center"
                                              HorizontalOptions="Center"/>
                                        <Label Text="{Binding Address}" HorizontalOptions="Center"/>
                                    </StackLayout>
                                </Frame>
                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!--实时温度-->
            <Grid ColumnDefinitions="*,60,Auto" 
                  RowDefinitions="*,*"
                  HeightRequest="50"
                  Margin="15,0">
                <Label Text="气象站"
                        VerticalOptions="Center"
                        HorizontalOptions="Start"
                        FontAttributes="Bold"
                        FontSize="15"
                        TextColor="#555"/>
                <Label Grid.Row="1" Text="刷新时间：10：00" TextColor="#AAA" FontSize="12"/>
                <Frame Grid.Column="1"
                       Grid.RowSpan="2"
                       Padding="0"
                       HeightRequest="30"
                       CornerRadius="16"
                       HorizontalOptions="Center"
                       VerticalOptions="Center">
                    <Button Text="设置" FontSize="12" Margin="0,-5,0,0" BackgroundColor="#85E65F"/>
                </Frame>

                <Frame Grid.Column="2"
                       Grid.RowSpan="2"
                       Padding="0"
                       HeightRequest="30"
                       CornerRadius="16"
                       HorizontalOptions="Center"
                       VerticalOptions="Center">
                    <Button Text="数据分析" FontSize="12" Margin="0,-5,0,0" BackgroundColor="#5FD4E6"/>
                </Frame>
            </Grid>

            <CollectionView ItemsSource="{Binding MonitorList}"
                            ItemsLayout="VerticalGrid,2"
                            Margin="10,5">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame Padding="0"
                               CornerRadius="5"
                               BackgroundColor="White"
                               BorderColor="Transparent"
                               Margin="5">
                            <Grid ColumnDefinitions="80,*"
                                  RowDefinitions="30,26,12"
                                  Padding="5">
                                <Label Text="{Binding Header}"
                                       FontAttributes="Bold"
                                       FontSize="12"/>
                                <Label Grid.Row="1">
                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span Text="{Binding Value}" TextColor="{Binding TextColor}" FontAttributes="Bold"/>
                                            <Span Text="{Binding Unit}" TextColor="{Binding TextColor}"/>
                                        </FormattedString>
                                    </Label.FormattedText>
                                </Label>
                                <Label Grid.Row="2">
                                    <!--数据显示触发器-->
                                    <Label.Triggers>
                                        <DataTrigger Binding="{Binding ChangeFlag}"
                                                     Value="0"
                                                     TargetType="Label">
                                            <Setter Property="IsVisible" Value="False"/>
                                        </DataTrigger>
                                    </Label.Triggers>
                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span Text="&#xe8f5;"
                                                  FontFamily="Iconfont"
                                                  TextColor="{Binding TextColor}"
                                                  FontSize="10"/>
                                            <Span Text="{Binding ChangeValue}" TextColor="{Binding TextColor}" FontSize="10"/>
                                            <Span Text="{Binding Unit}" TextColor="{Binding TextColor}" FontSize="10"/>
                                        </FormattedString>
                                    </Label.FormattedText>
                                </Label>

                                <Ellipse WidthRequest="40"
                                         HeightRequest="40"
                                         Fill="AliceBlue"
                                         Grid.Column="1"
                                         Grid.RowSpan="3"/>
                                <Label Text="{Binding Icon}"
                                       FontFamily="Iconfont"
                                       Grid.Column="1"
                                       Grid.RowSpan="3"
                                       VerticalOptions="Center"
                                       HorizontalOptions="Center"
                                       FontSize="22"/>
                            </Grid>
                        
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>